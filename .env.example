NODE_ENV=production
PORT=5001

# Required: Groq key for interview/question generation
GROQ_API_KEY=your_groq_api_key

# Recommended: Neon/Postgres URL for dashboard/history persistence
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated origins allowed by CORS
# Include your Vercel frontend URL
CORS_ORIGINS=https://mock-interviewer-client.vercel.app
